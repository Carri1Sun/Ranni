{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2023"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "declaration": false,
    "esModuleInterop": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "jsx": "react-jsx",
    "incremental": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "electron/**/*",
    "lib/**/*",
    "src/server/**/*"
  ],
  "exclude": ["dist", "node_modules", "src/renderer/**/*"]
}
